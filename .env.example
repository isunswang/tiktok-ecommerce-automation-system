# ============================================
# TikTok跨境电商全自动运营系统 - 环境变量模板
# 复制此文件为 .env 并填写实际值
# ============================================

# --- 应用配置 ---
APP_NAME=TikTok-Ops
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# --- PostgreSQL ---
POSTGRES_USER=tiktok_ops
POSTGRES_PASSWORD=tiktok_ops_dev
POSTGRES_DB=tiktok_ops
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://tiktok_ops:tiktok_ops_dev@localhost:5432/tiktok_ops

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_NAME=tiktok-ops-assets

# --- RabbitMQ ---
RABBITMQ_USER=tiktok_ops
RABBITMQ_PASSWORD=tiktok_ops_dev
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_URL=amqp://tiktok_ops:tiktok_ops_dev@localhost:5672/

# --- 后端服务 ---
BACKEND_PORT=8000
BACKEND_WORKERS=1

# --- Agent服务 ---
AGENT_PORT=8001
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your-openai-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.7

# --- 前端服务 ---
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- JWT认证 ---
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- TikTok Shop API (Mock模式) ---
TIKTOK_SHOP_API_URL=https://open-api.tiktokglobalshop.com
TIKTOK_SHOP_APP_KEY=your-app-key
TIKTOK_SHOP_APP_SECRET=your-app-secret
TIKTOK_SHOP_ACCESS_TOKEN=your-access-token
TIKTOK_SHOP_MOCK_MODE=true

# --- 1688 API (Mock模式) ---
ALIBABA_1688_APP_KEY=your-1688-app-key
ALIBABA_1688_APP_SECRET=your-1688-app-secret
ALIBABA_1688_MOCK_MODE=true

# --- 爬虫配置 ---
SCRAPER_CONCURRENCY=4
SCRAPER_DOWNLOAD_DELAY=2
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# --- Celery ---
CELERY_BROKER_URL=amqp://tiktok_ops:tiktok_ops_dev@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/2
